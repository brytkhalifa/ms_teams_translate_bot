# Copy to .env and fill in values. Used by: npm run dev (dotenv)

# HTTP server (default 3978)
# PORT=3978

# --- DeepL ---
# Opt-in to live API: 1, true, yes, on, or y (case-insensitive). Omit or any other value = echo adapter.
# DEEPL_MODE=1
# DEEPL_API_KEY=
# Optional override (defaults to DeepL free API host in code)
# DEEPL_API_URL=https://api-free.deepl.com
# Default target when the tab/API does not specify one
# DEEPL_TARGET_LANG=EN-US

# --- OpenAI ---
# Opt-in: same values as DEEPL_MODE. Omit or other value = echo adapter.
# OPENAI_MODE=1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional limits for POST /api/chat
# LLM_MAX_CONVERSATION_LENGTH=50
# LLM_MAX_TOTAL_CHARS=24000
