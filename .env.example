# Copy to .env and fill in values. Used by: npm run dev (dotenv)

# HTTP server (default 3978)
# PORT=3978

# --- DeepL ---
# Set DEEPL_MODE to enable the real API (any non-empty value, e.g. 1). Omit for echo adapter.
# DEEPL_MODE=1
# DEEPL_API_KEY=
# Optional override (defaults to DeepL free API host in code)
# DEEPL_API_URL=https://api-free.deepl.com
# Default target when the tab/API does not specify one
# DEEPL_TARGET_LANG=EN-US

# --- OpenAI ---
# Set OPENAI_MODE to enable the real API (any non-empty value, e.g. 1). Omit for echo adapter.
# OPENAI_MODE=1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
